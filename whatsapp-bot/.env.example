PORT=3000
NODE_ENV=development

# Límite del body JSON (validar/publicar flujos, simulador). El default de express es 100kb y provoca 413.
# En el código el default es 2mb; podés subirlo en producción si el flujo sigue creciendo.
# EXPRESS_JSON_LIMIT=5mb

# Docker: montar ./whatsapp-bot/data en /app/data (ver docker-compose en la raíz del repo).
# En contenedor conviene dejar PORT=3000 alineado con el mapeo de puertos del compose.

# Fase 1 — persistencia de conversaciones (SQL Server). Los flujos JSON no migran a DB.
#
# Nombre de la base: tea_bot (variable DB_NAME)
# Activar persistencia de conversaciones (si DB_* están completas, se auto-habilita en dev)
CONVERSATION_DB_ENABLED=true
#
# Conexión por variables (no hardcodear en código):
# DB_SERVER=localhost
# DB_PORT=1433
# DB_NAME=tea_bot
# DB_USER=sa
# DB_PASSWORD=TeaBot_Dev_Passw0rd!
#
# Docker Compose: DB_SERVER=sqlserver (nombre del servicio)
#
# TLS (Azure SQL u hospedaje con certificado):
# DB_ENCRYPT=true
# DB_TRUST_SERVER_CERTIFICATE=false
#
# Desarrollo local / SQL Server en Docker (sin TLS):
# DB_ENCRYPT=false
# DB_TRUST_SERVER_CERTIFICATE=true
#
# CONVERSATION_DB_STRICT=0

# Runtime de flujos: única fuente SQL Server (valores json legacy se ignoran)
FLOW_STORAGE_MODE=db

# Herramientas dev (POST /api/dev/conversations/*). En producción deben quedar deshabilitadas.
# DEV_TOOLS_ENABLED=false

# Seed local de conversaciones (solo dev; no envía Twilio)
# ALLOW_DEV_SEED=true
# RESET_DEV_SEED=true
# npm run db:seed-conversations
# npm run db:seed-conversations -- --reset

# Agente interno para assigned_agent_id sin tabla de usuarios
# INTERNAL_AGENT_ID=00000000-0000-4000-8000-000000000001
# DATABASE_POOL_MAX=10
# DATABASE_CONNECT_TIMEOUT_MS=15000
# DATABASE_REQUEST_TIMEOUT_MS=30000

# Admin panel (/api/flows, /api/simulator): login con cookie HTTP-only firmada
ADMIN_USERNAME=tea-bot
# SHA-256 hex de la contraseña (no guardar la contraseña en plano). Ejemplo para "Tea2026":
ADMIN_PASSWORD_HASH=
# Secreto largo para firmar la sesión (mínimo 32 caracteres)
SESSION_SECRET=cambiar_por_un_valor_largo_aleatorio_minimo_32_chars

# Meta WhatsApp Cloud API (obligatorias en producción)
META_VERIFY_TOKEN=pon_tu_verify_token
META_ACCESS_TOKEN=pon_tu_access_token
META_PHONE_NUMBER_ID=pon_tu_phone_number_id

# URL pública del backend (webhook, enlaces)
APP_BASE_URL=http://localhost:3000

# Twilio WhatsApp (V1 usa TwiML en webhook; SDK async futuro)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# CORS: con login, el navegador envía credenciales; incluí el origen exacto del frontend (CSV).
# Local: Vite suele ser :5173; Docker UI suele ser :8080.
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Google Sheets export configuration
# Enables exporting finalized WhatsApp bot conversations to Google Sheets.
# Keep disabled (`false`) to run without external export integration.
GOOGLE_SHEETS_ENABLED=false

# Google Sheet ID from the spreadsheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Sheet tab name where rows will be appended.
# Example: Conversaciones
GOOGLE_SHEETS_TAB_NAME=Conversaciones

# Optional tab for technical/raw conversation exports.
# Leave empty to disable raw export.
GOOGLE_SHEETS_RAW_TAB_NAME=

# Service Account email from the downloaded Google Cloud JSON key.
# Example: tea-bot-sheets-writer@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the downloaded Google Cloud JSON key.
# Keep the \n sequences exactly as they appear in the JSON.
# Wrap the value in double quotes in the real .env file.
# Example:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# Security notes:
# - Never commit the real JSON key file or the private key to the repository.
# - Share the target Google Sheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor.
# - If GOOGLE_SHEETS_ENABLED=true, the app expects:
#   GOOGLE_SHEETS_SPREADSHEET_ID, GOOGLE_SHEETS_TAB_NAME,
#   GOOGLE_SERVICE_ACCOUNT_EMAIL and GOOGLE_PRIVATE_KEY.

# Abandonment tracking (optional)
# Marks inactive conversations as abandoned and exports them.
ABANDON_TRACKING_ENABLED=false
ABANDON_TIMEOUT_MINUTES=30
ABANDON_SWEEP_INTERVAL_SECONDS=300
# Include simulator sessions in abandonment exports.
ABANDON_INCLUDE_SIMULATOR=false

# Export "info provided" intermediate events (non-terminal nodes).
# Keep false to log only final outcomes and avoid duplicate rows.
CONVERSATION_EXPORT_INFO_PROVIDED_EVENTS=false
