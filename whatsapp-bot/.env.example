PORT=3000
NODE_ENV=development

# Docker: montar ./whatsapp-bot/data en /app/data (ver docker-compose en la raíz del repo).
# En contenedor conviene dejar PORT=3000 alineado con el mapeo de puertos del compose.

# Meta WhatsApp Cloud API (obligatorias en producción)
META_VERIFY_TOKEN=pon_tu_verify_token
META_ACCESS_TOKEN=pon_tu_access_token
META_PHONE_NUMBER_ID=pon_tu_phone_number_id

# URL pública del backend (webhook, enlaces)
APP_BASE_URL=http://localhost:3000

# Twilio WhatsApp (V1 usa TwiML en webhook; SDK async futuro)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# CORS: en producción, lista CSV de orígenes del editor (ej. https://editor.tudominio.com).
# En desarrollo, si se omite, solo se permiten localhost / 127.0.0.1.
# CORS_ORIGIN=https://app.example.com,http://localhost:5173
