{
  "name": "whatsapp-bot",
  "version": "1.0.0",
  "description": "Base mínima para un chatbot de WhatsApp usando Meta WhatsApp Cloud API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "cli": "node src/cli/playground.js",
    "test": "node --test src/**/*.test.js",
    "test:unit": "node --test src/services/flow-engine.service.test.js",
    "db:migrate": "node src/db/migrate.js",
    "db:import-flows": "node scripts/import-flows-to-db.js",
    "flows:migrate-json-to-db": "node scripts/import-flows-to-db.js",
    "flows:parity-check": "node scripts/flow-json-db-parity.js",
    "db:seed-conversations": "node scripts/seed-local-conversations.js",
    "db:seed-local": "node scripts/seed-local-conversations.js",
    "db:verify": "node scripts/verify-platform-dod.js",
    "db:setup-local": "npm run db:migrate && npm run db:import-flows && ALLOW_DEV_SEED=true npm run db:seed-conversations",
    "bench:flows": "node scripts/benchmark-flow-runtime.js"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "meta",
    "express",
    "node"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "googleapis": "^171.4.0",
    "mssql": "^11.0.1"
  }
}
